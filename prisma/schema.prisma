generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===== 用戶系統 =====

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  emailVerified DateTime?           // required by NextAuth adapter
  name          String?             // display name (NextAuth compatible)
  image         String?             // avatar URL (NextAuth compatible)
  password      String?
  role          Role      @default(STUDENT)
  plan          Plan      @default(FREE)
  isActive      Boolean   @default(true)
  lastLogin     DateTime?
  referredBy    String?
  examDate      DateTime?

  // Nursing profile (collected at registration)
  nursingStatus      String?   // 護生 | RN | LPN | NP | 其他
  specialty          String?   // ICU | ER | Med-Surg | Pediatrics | OB | OR | ...
  yearsOfExperience  Int?      // 0, 1, 3, 5, 10...

  trialUsed            Boolean   @default(false)
  trialEndsAt          DateTime?
  subscriptionEndsAt   DateTime?
  createdAt            DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  settings         UserSettings?
  sessions         UserSession[]
  answers          UserAnswer[]
  bookmarks        Bookmark[]
  errorQuestions   ErrorQuestion[]
  dailyStats       UserDailyStats[]
  questionReports  QuestionReport[]
  feedbacks        Feedback[]
  achievements     UserAchievement[]
  questionNotes    QuestionNote[]
  betaSubscribers  BetaSubscriber[]
  orders           Order[]
  upgradeRequests  UpgradeRequest[]
  learnerProfile   LearnerProfile?
  hermesReports    HermesReport[]
  vocabProgress    UserVocabProgress[]
  vocabSessions    VocabSession[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// Required by NextAuth for email verification tokens
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserSettings {
  userId        String   @id
  dailyGoal     Int      @default(10)
  notification  Boolean  @default(true)
  theme         String   @default("dark")
  fontSize      String   @default("medium")
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  STUDENT
  MODERATOR
  ADMIN
}

enum Plan {
  FREE
  BASIC
  PRO
  ELITE
}

// ===== 題庫系統 =====

model Question {
  id            String         @id @default(uuid())
  module        Module         @default(NCLEX)
  questionType  QuestionType   @default(MCQ)

  // Stem (EN) and optional clinical scenario (EN + ZH)
  stem          String
  stemZh        String?
  scenarioEn    String?
  scenarioZh    String?

  // Up to 6 options (SATA needs 5–6, SBA/MCQ uses 4)
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  optionE       String?
  optionF       String?

  // For SBA/MCQ: single letter ("A"|"B"|"C"|"D")
  // For SATA:   comma-joined letters (e.g. "B,C,E")
  correctAnswer  String
  // Canonical multi-answer form (for SATA and future types)
  correctAnswers String[]       @default([])

  explanationZh  String
  explanationEn  String?
  usTwDifference String?

  // Per-option rationales (JSON: { "A": { "en": "...", "zh": "..." }, ... })
  optionRationales Json?

  // Categorisation
  domain        String?
  subDomain     String?
  tags          String[]       @default([])

  // Optional metadata from source pools (CJMM, Bloom's, setting, etc.)
  cjmmStep      String?
  bloomsLevel   String?
  caseStudySetId String?
  caseStudyPosition Int?

  // IRT parameters
  irtA          Float?
  irtB          Float?
  irtC          Float?
  difficulty    Difficulty     @default(MEDIUM)

  // Statistics
  attemptCount  Int            @default(0)
  correctCount  Int            @default(0)
  errorRate     Float          @default(0)

  // Management
  status        QuestionStatus @default(DRAFT)
  createdBy     String         @default("system")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Listening / audio (TOEIC Part 1-4 etc.)
  audioScript   String?        // Source script for TTS (may include "Speaker A:" markers)
  audioDurationSec Float?      // Total duration of latest audio asset
  hasAudio      Boolean        @default(false)

  answers        UserAnswer[]
  bookmarks      Bookmark[]
  errorQuestions ErrorQuestion[]
  reports        QuestionReport[]
  notes          QuestionNote[]
  audioAssets    AudioAsset[]
  qualityIssues  QuestionQualityIssue[]
  versions       QuestionVersion[]

  @@index([module, status])
  @@index([domain])
  @@index([difficulty])
  @@index([caseStudySetId])
}

// ===== Audio assets (TOEIC listening / general TTS) =====

model AudioAsset {
  id           String   @id @default(uuid())
  questionId   String
  data         Bytes                          // raw audio bytes (WAV)
  mimeType     String   @default("audio/wav")
  durationSec  Float?
  sampleRate   Int      @default(24000)
  voicesUsed   String[] @default([])          // e.g. ["Kore", "Puck"]
  scriptHash   String?                         // dedup detection
  modelUsed    String?                         // gemini-2.5-flash-preview-tts ...
  createdAt    DateTime @default(now())

  question     Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

enum Module {
  NCLEX
  TOEIC
  IELTS
}

enum QuestionType {
  MCQ
  SATA
  ORDERED
  MATRIX
  BOWTIE
  DROPDOWN
  HIGHLIGHT
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionStatus {
  DRAFT
  APPROVED
  ARCHIVED
}

// ===== 答題系統 =====

model UserSession {
  id             String      @id @default(uuid())
  userId         String
  module         Module      @default(NCLEX)
  mode           SessionMode
  isAssessment   Boolean     @default(false)

  // CAT state
  theta          Float       @default(0)
  se             Float       @default(1)
  questionIds    String[]    @default([])  // Questions that were *served* so far (used to avoid repeats)

  // Config (set on create)
  targetCount    Int?        // Target total questions (Practice/Tutor/Mock)
  timeLimitSec   Int?        // Max duration (Mock/Assessment)
  domainFilter   String[]    @default([])  // Optional list of domain names
  difficultyFilter String[]  @default([])  // "EASY" | "MEDIUM" | "HARD"

  // Statistics
  totalQuestions Int         @default(0)
  correctCount   Int         @default(0)
  score          Float?
  passFail       String?
  totalTimeSec   Int         @default(0)
  stopReason     String?     // 95_confidence | max_questions | time_limit | se_reached | user_end | etc.

  // Pause state
  isPaused       Boolean     @default(false)
  pausedAt       DateTime?

  startedAt      DateTime    @default(now())
  endedAt        DateTime?

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers   UserAnswer[]
  diagnosis SessionDiagnosis?

  @@index([userId, mode])
  @@index([userId, endedAt])
}

enum SessionMode {
  CAT
  PRACTICE
  TUTOR
  MOCK
  REVIEW
  ASSESSMENT
  MINI_CAT
  ERROR_CHALLENGE
}

model UserAnswer {
  id             String      @id @default(uuid())
  sessionId      String
  userId         String
  questionId     String
  selectedAnswer String?     // For SBA: "A"; For SATA: "B,C,E"
  isCorrect      Boolean?
  timeSpentSec   Int?
  thetaBefore    Float?
  thetaAfter     Float?
  seAfter        Float?
  answeredAt     DateTime    @default(now())

  session  UserSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id])

  @@unique([sessionId, questionId])
  @@index([sessionId, answeredAt])
  @@index([userId, answeredAt])
}

model Bookmark {
  id         String   @id @default(uuid())
  userId     String
  questionId String
  note       String?
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
}

model QuestionNote {
  id         String   @id @default(uuid())
  userId     String
  questionId String
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
}

// ===== 錯題系統（SM-2）=====

model ErrorQuestion {
  id          String   @id @default(uuid())
  userId      String
  questionId  String
  repetition  Int      @default(0)
  easiness    Float    @default(2.5)
  interval    Int      @default(1)
  nextReview  DateTime @default(now())
  lastWrongAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
}

// ===== 統計系統 =====

model UserDailyStats {
  id            String   @id @default(uuid())
  userId        String
  statDate      DateTime @db.Date
  questionsDone Int      @default(0)
  correctCount  Int      @default(0)
  timeSpentMin  Int      @default(0)
  sessionsCount Int      @default(0)
  domainStats   Json     @default("{}")
  streakDay     Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, statDate])
}

// ===== 成就系統 =====

model Achievement {
  id          String  @id @default(uuid())
  key         String  @unique
  name        String
  description String
  icon        String
  users       UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(uuid())
  userId        String
  achievementId String
  earnedAt      DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
}

// ===== 每日挑戰 =====

model DailyChallenge {
  id            String   @id @default(uuid())
  questionId    String
  date          DateTime @db.Date @unique
  totalAttempts Int      @default(0)
  correctCount  Int      @default(0)
  createdAt     DateTime @default(now())

  attempts      DailyChallengeAttempt[]
}

model DailyChallengeAttempt {
  id             String   @id @default(uuid())
  challengeId    String
  userId         String
  selectedAnswer String
  isCorrect      Boolean
  createdAt      DateTime @default(now())

  challenge DailyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@index([userId])
}

// ===== 回報與回饋 =====

model QuestionReport {
  id         String   @id @default(uuid())
  userId     String
  questionId String
  /** Free-text reason (legacy). Prefer reasonCategory for new reports. */
  reason     String
  /** Structured reason; one of QuestionReportReason. */
  reasonCategory String?  // INCORRECT_ANSWER | TYPO | UNCLEAR_STEM | OUTDATED_INFO | UI_BUG | OTHER
  /** Optional letter pointing at the suspect option (A/B/C/D/E/F). */
  targetOption   String?
  detail     String?
  /** PENDING | IN_REVIEW | RESOLVED_FIXED | RESOLVED_INVALID | RESOLVED_DUPLICATE */
  status     String   @default("PENDING")
  /** Triage outcome by the AI agent (NEEDS_FIX | LIKELY_VALID | LIKELY_INVALID | UNCERTAIN). */
  triageVerdict   String?
  triageNotes     String?
  triagedByModel  String?
  triagedAt       DateTime?
  /** Assigned admin user ID for manual handling. */
  assignedTo     String?
  resolvedAt     DateTime?
  resolvedBy     String?
  resolution     String?  // text describing what was done
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([questionId, status])
}

// AI / rule-based detected quality issues (auto + cron)
model QuestionQualityIssue {
  id         String   @id @default(uuid())
  questionId String
  /** Rule identifier, e.g. "adverb_pollution", "answer_explanation_mismatch". */
  ruleId     String
  /** LOW | MEDIUM | HIGH | CRITICAL */
  severity   String   @default("MEDIUM")
  /** Human-readable explanation of what was found. */
  detail     String
  /** Optional structured metadata from the rule (counts, indices, etc). */
  meta       Json?
  /** OPEN | RESOLVED | IGNORED | AUTO_ARCHIVED */
  status     String   @default("OPEN")
  /** Hash of relevant question content at detection time (to dedupe). */
  contentHash String?
  detectedAt  DateTime @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?
  resolution  String?

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([status, severity])
  @@index([ruleId, status])
  @@unique([questionId, ruleId, contentHash])
}

// Version control for question edits (rollback / audit)
model QuestionVersion {
  id           String   @id @default(uuid())
  questionId   String
  /** Snapshot of all edited fields */
  snapshot     Json
  /** Who triggered the change: admin userId, "agent:repair", "import:batch-X", etc */
  changedBy    String
  /** Optional reason / commit-message-style note */
  reason       String?
  /** True if change was a result of an automated agent action */
  agentInitiated Boolean @default(false)
  createdAt    DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId, createdAt(sort: Desc)])
}

// Marketing content generated by marketing-team agents
model MarketingContent {
  id           String   @id @default(uuid())
  /** SEO_ARTICLE | SOCIAL_POST | EMAIL | LANDING_COPY | AD_COPY */
  contentType  String
  /** Target platform: blog | x | linkedin | facebook | instagram | newsletter | google-ads */
  platform     String?
  title        String?
  body         String   @db.Text
  /** Generated meta tags for SEO */
  meta         Json?
  /** "draft" | "approved" | "published" | "archived" */
  status       String   @default("draft")
  modelUsed    String?
  generatedAt  DateTime @default(now())
  approvedAt   DateTime?
  publishedAt  DateTime?
  publishedUrl String?
  metrics      Json?    // impressions, clicks, conversions etc

  @@index([contentType, status])
  @@index([generatedAt(sort: Desc)])
}

// Daily / weekly health-report snapshots for the dashboard
model QualityHealthReport {
  id              String   @id @default(uuid())
  /** "daily" | "weekly" | "manual" */
  periodType      String
  /** "2026-04-27" | "2026-W17" */
  period          String
  totalQuestions  Int
  approvedCount   Int
  draftCount      Int
  archivedCount   Int
  openIssueCount  Int
  /** 0-100 health score */
  healthScore     Int
  summary         Json     // { byRule: {...}, bySeverity: {...}, trends: {...} }
  /** Markdown narrative for human reading */
  narrative       String?  @db.Text
  modelUsed       String?
  createdAt       DateTime @default(now())

  @@index([periodType, createdAt(sort: Desc)])
  @@unique([periodType, period])
}

model Feedback {
  id        String   @id @default(uuid())
  userId    String?
  sessionId String?
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

// ===== Beta 訂閱 =====

model BetaSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  userId    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

// ===== 訂單（預留）=====

model Order {
  id          String   @id @default(uuid())
  userId      String
  plan        Plan
  billing     String   // monthly | quarterly | yearly
  amount      Int      // NT$
  currency    String   @default("TWD")
  status      String   @default("pending") // pending | paid | failed | cancelled
  paymentRef  String?  // 藍新交易序號
  createdAt   DateTime @default(now())
  paidAt      DateTime?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

// ===== 升級申請（手動付款）=====

model UpgradeRequest {
  id        String   @id @default(uuid())
  userId    String
  plan      Plan
  billing   String   // monthly | quarterly | yearly
  status    String   @default("pending") // pending | contacted | completed | cancelled
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([userId])
}

// ===== Hermes Agent Layer =====

model LearnerProfile {
  id                  String   @id @default(uuid())
  userId              String   @unique

  // Weakness map: { "Management of Care": 0.45, ... } — accuracy per domain
  domainMastery       Json     @default("{}")

  // Top 3 recurring error taxonomy labels
  topWeaknesses       String[] @default([])

  // Behaviour flags detected across sessions
  behaviorPatterns    Json     @default("[]")
  // e.g. ["always_picks_safety_not_best","sata_underselects","changes_correct_answer"]

  // Mistake taxonomy counts: { "Knowledge Gap": 12, "Priority Mistake": 7, ... }
  mistakeCounts       Json     @default("{}")

  // Overall confidence band: low | developing | stable | high
  confidenceBand      String   @default("developing")

  // Trend over last 7 sessions: improving | stable | declining
  recentTrend         String   @default("stable")

  // Free-text AI-generated summary (≤300 chars), refreshed after each session
  insightSummary      String?

  // Today's 3-5 concrete next actions (e.g. "練 10 題 SATA")
  nextActions         Json     @default("[]")

  // 3-day study plan: [{day:1, focus:"...", questions:10}, ...]
  studyPlan           Json     @default("[]")

  // Theta trajectory: last 10 theta values
  thetaHistory        Float[]  @default([])

  // Total sessions analysed
  sessionsAnalysed    Int      @default(0)

  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SessionDiagnosis {
  id            String   @id @default(uuid())
  sessionId     String   @unique
  userId        String

  // Classified mistake types found in this session
  mistakeTypes  String[] @default([])
  // ["Knowledge Gap","Priority Mistake","SATA Strategy Error",...]

  // Root cause summary (AI-generated, ≤200 chars)
  rootCauses    String?

  // Key insight sentence for this session
  keyInsight    String?

  // Severity 1-5
  severity      Int      @default(3)

  // Domains most problematic in this session
  weakDomains   String[] @default([])

  // Was the Hermes analysis completed?
  analysed      Boolean  @default(false)

  createdAt     DateTime @default(now())

  session       UserSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ===== Hermes Job Queue =====

model HermesJob {
  id          String   @id @default(uuid())
  userId      String
  sessionId   String
  status      String   @default("pending")
  // pending | running | done | failed
  attempts    Int      @default(0)
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, createdAt])
  @@index([userId])
}

// ===== App-wide Settings (key/value) =====

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ===== Hermes Report History =====

model HermesReport {
  id             String   @id @default(uuid())
  userId         String
  sessionId      String?
  type           String   @default("session")  // "session" | "weekly"

  insightSummary String?
  nextActions    Json     @default("[]")
  studyPlan      Json     @default("[]")
  keyInsight     String?
  rootCauses     String?
  mistakeTypes   String[] @default([])
  weakDomains    String[] @default([])
  confidenceBand String?
  recentTrend    String?

  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

// ===== Background AI Question Generation Job =====

model GenerationJob {
  id          String   @id @default(uuid())
  status      String   // RUNNING | STOPPED | COMPLETED | FAILED
  target      Int
  model       String
  domain      String   // "auto" or specific domain name
  batchCount  Int      @default(0)
  inserted    Int      @default(0)
  rejected    Int      @default(0)
  duplicates  Int      @default(0)
  errors      Int      @default(0)
  lastMessage String?
  createdBy   String?
  startedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, startedAt(sort: Desc)])
}

// ===== Vocabulary (NCLEX-RN) =====

model VocabularyWord {
  id           String   @id @default(uuid())
  word         String   @unique
  partOfSpeech String?                // noun | verb | adjective | abbr
  definitionEn String
  definitionZh String
  category     String                  // Pharmacology | Assessment | Pathophysiology | ...
  tier         Int      @default(1)    // 1 foundation | 2 clinical | 3 advanced
  difficulty   Difficulty @default(MEDIUM)
  exampleEn    String?
  exampleZh    String?
  synonyms     String[] @default([])
  memoryHook   String?                 // etymology / mnemonic (no phonetics)
  tags         String[] @default([])
  status       QuestionStatus @default(APPROVED)
  createdBy    String   @default("claude")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  progress     UserVocabProgress[]

  @@index([category])
  @@index([tier])
  @@index([status])
}

// SM-2 per-user per-word progress
model UserVocabProgress {
  id           String   @id @default(uuid())
  userId       String
  wordId       String
  repetition   Int      @default(0)
  easiness     Float    @default(2.5)
  interval     Int      @default(1)       // days until next review
  nextReview   DateTime @default(now())
  lastResult   String?                    // again | hard | good | easy
  seenCount    Int      @default(0)
  correctCount Int      @default(0)
  mastered     Boolean  @default(false)
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  word VocabularyWord @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId])
  @@index([userId, nextReview])
  @@index([userId, mastered])
}

enum VocabSessionMode {
  FLASHCARD     // 正面英文 → 翻面看中文 + 例句
  QUIZ          // 英文 → 中文四選一
  SPELLING      // 中文 → 拼出英文單字
  DEFINITION    // 英文定義 → 選正確單字
}

model VocabSession {
  id            String           @id @default(uuid())
  userId        String
  mode          VocabSessionMode
  tier          Int?
  category      String?
  wordIds       String[]         @default([])
  totalWords    Int              @default(0)
  correctCount  Int              @default(0)
  timeSpentSec  Int              @default(0)
  startedAt     DateTime         @default(now())
  endedAt       DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt(sort: Desc)])
}

// ===== API Usage / Cost Tracking =====

model ApiUsageLog {
  id               String   @id @default(uuid())
  userId           String?
  model            String
  inputTokens      Int
  outputTokens     Int
  cacheReadTokens  Int      @default(0)
  cacheWriteTokens Int      @default(0)
  purpose          String   // "hermes_analytics" | "hermes_teaching" | "chat"
  costUsd          Float

  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}

// ===== Ops Agent Reports =====

model OpsReport {
  id           String   @id @default(uuid())
  period       String   // "2026-W17" | "2026-04-23"
  periodType   String   // "weekly" | "daily" | "manual"
  status       String   @default("pending") // pending | running | done | error
  model        String   // e.g. "gemini-2.5-flash"
  // Per-agent outputs
  ctoReport    Json?    // bug scan, code quality findings
  pmReport     Json?    // UX feedback, feature requests
  opsReport    Json?    // MAU/DAU, revenue, upgrade requests
  // Final supervisor summary
  summaryZh    String?  // 繁體中文綜合報告 (markdown)
  // Metadata
  durationMs   Int      @default(0)
  error        String?
  triggeredBy  String?  // admin userId or "cron"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([periodType, createdAt(sort: Desc)])
}

// ===== Agent self-learning memory =====
//
// Every agent run (ops, quality, marketing, etc) writes one AgentMemory row.
// Subsequent runs of the same agent type read recent rows as few-shot
// context: "last week you did X with result Y, admin rated Z stars".
// This is the foundation for actual self-improvement — the agent sees its
// own past performance instead of starting from a blank slate every time.
model AgentMemory {
  id           String   @id @default(uuid())
  /** Agent identity. Examples: "ops.cto", "quality.verify", "marketing.seo".
   *  Free-form so new agents can register without a schema change. */
  agentType    String
  /** Human-readable slug for the unit of work, e.g. session id, report id,
   *  or "daily-2026-04-30". Lets us link memory back to source rows. */
  taskKey      String?
  /** Compact summary of the input the agent saw (≤ 500 chars). */
  inputSummary String   @db.Text
  /** Compact summary of what the agent produced (≤ 1000 chars). */
  outputSummary String  @db.Text
  /** Full raw output if available (JSON or text) — used for replay/debug. */
  rawOutput    Json?
  /** Model id used for this run, e.g. "deepseek-ai/deepseek-v4-flash". */
  modelUsed    String?
  /** End-to-end ms from agent invocation to result. */
  durationMs   Int      @default(0)
  /** Whether the run completed without throwing. */
  ok           Boolean  @default(true)
  error        String?
  createdAt    DateTime @default(now())

  evaluations  AgentEvaluation[]

  @@index([agentType, createdAt(sort: Desc)])
  @@index([taskKey])
}

// ===== Admin feedback on agent output =====
//
// Admin can give thumbs-up / thumbs-down + optional note on any AgentMemory
// row. The next run of that agent reads recent positive examples as "do
// more of this" and negative examples as "avoid this pattern".
model AgentEvaluation {
  id          String   @id @default(uuid())
  memoryId    String
  /** -1 (bad), 0 (neutral), 1 (good). */
  rating      Int
  /** Optional admin note on what was wrong/right. */
  note        String?  @db.Text
  /** Admin user id who rated this. */
  ratedBy     String
  createdAt   DateTime @default(now())

  memory      AgentMemory @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@index([memoryId])
  @@index([rating, createdAt(sort: Desc)])
}

// ===== Claude manual question audit (Patch 2) =====
//
// Records every question Claude personally reviewed. One row per pass over
// the bank — multiple sessions over multiple days ladder up under one
// ClaudeAuditSession. Each ClaudeAuditDecision records what was found and
// what was changed (or NOT changed, with reason).
//
// Why a separate table from QuestionVersion: rollback semantics and progress
// tracking. Admin can revert "everything Claude touched in session X" with
// one click without affecting other version history.
model ClaudeAuditSession {
  id              String   @id @default(uuid())
  /** Human label for this audit pass, e.g. "2026-05-pass-1". */
  label           String
  /** ACTIVE | PAUSED | COMPLETED | ROLLED_BACK */
  status          String   @default("ACTIVE")
  /** Total questions targeted (typically 14323 for full NCLEX bank). */
  targetTotal     Int      @default(0)
  /** How many decisions written so far. */
  processedCount  Int      @default(0)
  /** How many resulted in actual writes to Question. */
  changedCount    Int      @default(0)
  /** How many were left untouched (already good). */
  unchangedCount  Int      @default(0)
  /** How many were marked DRAFT for human review (e.g. answer disputes). */
  flaggedCount    Int      @default(0)
  startedAt       DateTime @default(now())
  finishedAt      DateTime?
  /** Free-form notes / why the session was paused / etc. */
  notes           String?  @db.Text

  decisions       ClaudeAuditDecision[]

  @@index([status, startedAt(sort: Desc)])
}

model ClaudeAuditDecision {
  id              String   @id @default(uuid())
  sessionId       String
  questionId      String
  /** UNCHANGED | EDITED | FLAGGED_FOR_REVIEW | ROLLED_BACK */
  decision        String
  /** What changed (field names → before/after). Null when UNCHANGED. */
  changeSummary   Json?
  /** Snapshot of full Question row before our edit (for rollback). */
  beforeSnapshot  Json?
  /** Snapshot of full Question row after our edit. */
  afterSnapshot   Json?
  /** Claude's reasoning, ≤ 500 chars. */
  reasoning       String?  @db.Text
  /** 0-100; only writes >= 85 actually edit Question. */
  confidence      Int      @default(0)
  /** True when this decision was rolled back via /api/admin/audit-sessions/[id]/rollback. */
  rolledBack      Boolean  @default(false)
  rolledBackAt    DateTime?
  createdAt       DateTime @default(now())

  session         ClaudeAuditSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt(sort: Desc)])
  @@index([questionId])
  @@index([decision])
}
