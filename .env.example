# ===== Database =====
DATABASE_URL="postgresql://root:PASSWORD@HOST:PORT/zeabur"

# ===== Redis =====
REDIS_URL="redis://:PASSWORD@HOST:PORT"

# ===== MinIO =====
MINIO_ENDPOINT="HOST"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY="minio"
MINIO_SECRET_KEY="YOUR_SECRET"
MINIO_BUCKET="nurslix-main"

# ===== NextAuth v5 =====
# Generate with: openssl rand -base64 32
AUTH_SECRET="run: openssl rand -base64 32"
AUTH_URL="https://nurslix.zeabur.app"

# ===== Google OAuth =====
# Create at https://console.cloud.google.com/
# Authorised redirect URI: https://nurslix.zeabur.app/api/auth/callback/google
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# ===== Gmail SMTP =====
GMAIL_USER="your@gmail.com"
GMAIL_APP_PASSWORD="YOUR_APP_PASSWORD"

# ===== App =====
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://nurslix.zeabur.app"
