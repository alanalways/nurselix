# ===== Database =====
DATABASE_URL="postgresql://root:PASSWORD@HOST:PORT/zeabur"

# ===== Redis =====
REDIS_URL="redis://:PASSWORD@HOST:PORT"

# ===== MinIO =====
MINIO_ENDPOINT="HOST"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY="minio"
MINIO_SECRET_KEY="YOUR_SECRET"
MINIO_BUCKET="nurslix-main"

# ===== NextAuth v5 =====
# Generate with: openssl rand -base64 32
AUTH_SECRET="run: openssl rand -base64 32"
AUTH_URL="https://nurslix.zeabur.app"

# ===== Google OAuth =====
# Create at https://console.cloud.google.com/
# Authorised redirect URI: https://nurslix.zeabur.app/api/auth/callback/google
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# ===== Gmail SMTP =====
GMAIL_USER="your@gmail.com"
GMAIL_APP_PASSWORD="YOUR_APP_PASSWORD"

# ===== NewebPay (藍新金流) =====
# 取得自 https://cwww.newebpay.com/merchant_apply
NEWEBPAY_MERCHANT_ID="MS12345678"
NEWEBPAY_HASH_KEY="YOUR_HASH_KEY"
NEWEBPAY_HASH_IV="YOUR_HASH_IV"
# 正式站: https://core.newebpay.com/MPG/mpg_gateway
# 測試站: https://ccore.newebpay.com/MPG/mpg_gateway
NEWEBPAY_API_URL="https://ccore.newebpay.com/MPG/mpg_gateway"
NEWEBPAY_VERSION="2.0"

# ===== Anthropic (Claude AI) =====
# 取得自 https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."

# ===== Cron Jobs =====
# Generate with: openssl rand -hex 32 (use ≥32 chars)
CRON_SECRET="your_cron_secret_here"

# ===== Hermes admin endpoints =====
# Used by /api/admin/hermes/retry, /weekly-report, /exam-reminder.
# Either this key OR CRON_SECRET is accepted as Bearer token.
HERMES_ADMIN_API_KEY="your_hermes_admin_key"

# ===== Sentry (optional — error tracking) =====
# Server-side DSN (also used by edge runtime). Leave empty to disable.
SENTRY_DSN=""
# Public DSN for the browser bundle. Usually same value as SENTRY_DSN.
NEXT_PUBLIC_SENTRY_DSN=""
# Environment label shown in Sentry dashboard (production | preview | local).
SENTRY_ENV="production"
NEXT_PUBLIC_SENTRY_ENV="production"
# Source-map upload (only needed for CI-built images). Leave empty locally.
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# ===== App =====
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://nurslix.zeabur.app"
NEXT_PUBLIC_SITE_URL="https://nurslix.zeabur.app"
